DATABASE_URL="file:./dev.db"
PANDASCORE_API_KEY=""
GRID_API_KEY=""
LIQUIPEDIA_API_KEY=""
FACEIT_API_KEY=""
LEETIFY_API_KEY=""
THESPORTSDB_API_KEY=""
ESIC_API_KEY=""
PRIVATE_INBOX_PATH="./data/private-inbox"
ENABLE_MOCK_DATA=true
ENABLE_ANALYST_SAMPLE=false
ENABLE_REAL_IMPORTS=false
ENABLE_ESPORTIS_SYNC=false
ENABLE_PANDASCORE_SYNC=false
ENABLE_GRID_SYNC=false
ENABLE_LIQUIPEDIA_SYNC=false
ENABLE_FACEIT_SYNC=false
ENABLE_LEETIFY_SYNC=false
ENABLE_THESPORTSDB_SYNC=false
ENABLE_TELEGRAM_NEWS_SYNC=false
ENABLE_VALVE_RANKINGS_SYNC=false
ENABLE_CS_UPDATES_SYNC=false
ENABLE_TRUSTED_LOCAL_IMPORTS=false
ENABLE_SAFE_HARVESTER=false
ENABLE_CSSTATS_AUTO_LOOKUP=false
STEAM_API_KEY=""
ENABLE_STEAM_SYNC=false
ENABLE_AUTO_ALL_RESOLVER=false
AUTO_SYNC_ENABLED=false
SYNC_INTERVAL_MINUTES=180
PRE_MATCH_REFRESH_MINUTES=120
POST_MATCH_REFRESH_MINUTES=60

# Optional extended sources for data:auto-all:extended (off by default)
ENABLE_RESEARCH_SOURCES=false
ENABLE_HLTV_AUTOMATION=false
ENABLE_CSSTATS_DEMO_FETCH=false
ENABLE_BO3_CS2API_SYNC=false
ENABLE_WAYBACK_FALLBACK=false
ENABLE_ARCHIVE_TODAY_FALLBACK=false
ENABLE_RSS_METADATA_DISCOVERY=false
ENABLE_SITEMAP_EXPORT_DISCOVERY=false
ENABLE_GRAPHQL_DISCOVERY=false
ENABLE_JINA_PROXY_FALLBACK=false
ENABLE_GOOGLE_CSE_FALLBACK=false
GOOGLE_CSE_API_KEY=""
GOOGLE_CSE_CX=""
GOOGLE_CSE_DAILY_QUOTA=100
ENABLE_COMMUNITY_DATASETS=false
RESEARCH_DEMO_PARSER_CMD=""
ALLOW_RESEARCH_NO_CACHE=false

# Local AI import assistant (Ollama, text-first, off by default)
ENABLE_LOCAL_AI=false
LOCAL_AI_MODEL="llama3.2:3b"
LOCAL_AI_FINETUNED_MODEL="cs2-prediction-finetuned"
LOCAL_AI_BASE_URL="http://127.0.0.1:11434"
LOCAL_AI_TIMEOUT_MS=60000
AI_AUTO_APPLY_ENABLED=false
AI_AUTO_APPLY_MIN_CONFIDENCE=85
AI_AUTO_APPLY_DELAY_MS=5000
AI_HISTORY_RETAIN_DAYS=30
AI_HISTORY_INPUT_CHARS=500
AI_HISTORY_FULL_INPUT=false
AI_FINETUNE_ALLOW_RUN=false

# Local automation (safe by default; never applies analyst sheets automatically)
ENABLE_AUTO_PIPELINE=false
AUTO_PIPELINE_INTERVAL_HOURS=6
AUTO_PIPELINE_MODE=max
AUTO_PIPELINE_DRY_RUN=false
AUTO_PIPELINE_MATCH_LIMIT=10
ENABLE_AUTO_SOURCE_SYNC=false
AUTO_SOURCE_SYNC_INTERVAL_HOURS=24
ENABLE_AUTO_FINETUNE=false
AUTO_CLEANUP_INTERVAL_HOURS=168
AUTO_CLEANUP_WRITE=false
ENABLE_NOTIFICATIONS=false
