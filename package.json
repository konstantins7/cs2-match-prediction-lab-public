{
  "name": "cs2-match-prediction-lab",
  "version": "0.9.2",
  "private": true,
  "packageManager": "pnpm@11.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit --incremental false",
    "test": "vitest run",
    "check:dev-log": "tsx src/scripts/checkDevLog.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "sync:all": "tsx src/scripts/sync.ts all",
    "sync:pandascore-free": "tsx src/scripts/sync.ts pandascore-free",
    "sync:snapshots": "tsx src/scripts/sync.ts snapshots",
    "sync:predictions": "tsx src/scripts/sync.ts predictions",
    "data:fetch-esportis": "tsx tools/data-fetchers/fetch-esportis.ts --force",
    "data:fetch-pandascore": "tsx tools/data-fetchers/fetch-pandascore.ts --force",
    "data:fetch-grid": "tsx tools/data-fetchers/fetch-grid.ts --force",
    "data:fetch-liquipedia-rosters": "tsx tools/data-fetchers/fetch-liquipedia-rosters.ts --force",
    "data:fetch-valve-rankings": "tsx tools/data-fetchers/fetch-valve-rankings.ts --force",
    "data:fetch-all": "tsx tools/run-all-fetchers.ts",
    "harvest": "tsx tools/data-harvesters/harvest-all.ts",
    "data:pipeline": "tsx src/scripts/analyticsPipeline.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.3.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "npm": "^10.9.0",
    "postcss": "^8.4.49",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  }
}
