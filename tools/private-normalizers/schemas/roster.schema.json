{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Private normalized roster.csv",
  "type": "object",
  "required": ["matchId", "teamName", "nickname", "sourceName", "collectedAt", "period", "sampleSize", "confidence"],
  "properties": {
    "matchId": { "type": "string", "minLength": 1 },
    "teamName": { "type": "string", "minLength": 1 },
    "nickname": { "type": "string", "minLength": 1 },
    "role": { "type": "string" },
    "country": { "type": "string" },
    "sourceName": { "type": "string", "minLength": 1 },
    "collectedAt": { "type": "string" },
    "period": { "type": "string", "minLength": 1 },
    "sampleSize": { "type": "number", "exclusiveMinimum": 0 },
    "confidence": { "type": "number", "exclusiveMinimum": 0 },
    "sourceUrl": { "type": "string" }
  }
}
